    "editor.lineHighlightBorder":           "#00000000",
    "editor.selectionBackground":           "#2A4A0066",
    "editor.selectionHighlightBackground":  "#2A4A0044",
    "editor.wordHighlightBackground":       "#33550033",
    "editor.wordHighlightStrongBackground": "#3A6A0044",
    "editor.findMatchBackground":           "#88FF0044",
    "editor.findMatchHighlightBackground":  "#AAFF0022",
    "editor.rangeHighlightBackground":      "#AAFF0011",
    "editorCursor.foreground":              "#AAFF00",
    "editorCursor.background":              "#000000",
    "editorWhitespace.foreground":          "#1E2E08",
    "editorIndentGuide.background":         "#1A2808",
